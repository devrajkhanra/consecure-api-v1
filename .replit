modules = ["nodejs-20", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
NODE_ENV = "development"
PORT = "5000"
DB_HOST = "helium"
DB_PORT = "5432"
DB_USER = "postgres"
DB_DATABASE = "heliumdb"
DB_SSL = "false"
JWT_ACCESS_SECRET = "570182cd58d9acf192d4a71bd7c3569a1c72c6b530526c3d8b5e4f428f1301646af992871bc6041d18aa05fea2aabb8fa6cf90af08609d745f78a3f6bc96dbcb"
JWT_REFRESH_SECRET = "1d4a0429e913813da541c997f5b56a00b3fef8ab9dd0f09e37417facd9a087ab37ff0dc69975df85ffc3e0aa6f95090785a604cae8a5ad8a25f57b4eeed283ac"
JWT_ACCESS_EXPIRES_IN = "900"
JWT_REFRESH_EXPIRES_IN = "604800"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run start:dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["node", "dist/main"]
build = ["npm", "run", "build"]
