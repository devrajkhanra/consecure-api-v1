# Environment variables for local development (copy to .env and fill secrets)
NODE_ENV=development
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=root
DB_DATABASE=consecure_dev
DB_SSL=false
JWT_ACCESS_SECRET=your_jwt_access_secret_is_32_characters_long
JWT_REFRESH_SECRET=your_jwt_refresh_secret_is_32_characters_long

# TYPEORM_SYNC has been permanently removed.
# Schema migrations are managed exclusively via:
#   npx typeorm migration:generate src/migrations/<Name> -- -d src/data-source.ts
#   npx typeorm migration:run -- -d src/data-source.ts
#
# Never set synchronize: true in any environment. It will DROP columns on
# entity renames and cause data loss in concurrent deployments.

# Optional overrides
# LOG_LEVEL=debug      # default: debug (dev) / info (prod)
# PORT=3000